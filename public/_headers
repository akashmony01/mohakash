# Security headers served by Cloudflare Pages for every route.
#
# NOTE: Cloudflare COMBINES headers from every matching rule (it does not let a
# more specific path override). Two CSP headers means the browser enforces the
# intersection (the strictest), so a separate looser /admin rule can't relax the
# site-wide one — it only further restricts. Therefore we use a SINGLE CSP that
# also satisfies the Sveltia CMS at /admin (which calls the GitHub API). The
# strong directives are kept; only connect-src/img-src are opened to https so the
# CMS works. 'unsafe-inline'/'unsafe-eval' are required by Astro inline scripts
# and Alpine.js.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https:; frame-src 'self' https://www.youtube-nocookie.com https://www.youtube.com; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests
