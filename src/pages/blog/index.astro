---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import pages from '../../data/pages.json';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = ['All', 'Building with Claude', 'Notes', 'Dev'] as const;

const readingTime = (body = '') =>
  Math.max(1, Math.round(body.split(/\s+/).filter(Boolean).length / 200));

const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout
  title="Blog — Mohammed Akash"
  description="Thinking in public by Mohammed Akash — notes on building with Claude, development, and ideas worth keeping."
>
  <section class="mx-auto max-w-6xl px-5 py-14" x-data="{ cat: 'All' }">
    <SectionHero
      title={pages.blog.title}
      intro={pages.blog.intro}
      tint="#1a8fd6"
      motif="blog"
    />

    <!-- Category filter -->
    <div class="mb-10 flex flex-wrap gap-2">
      {categories.map((c) => (
        <button
          @click={`cat = '${c}'`}
          :class={`cat === '${c}' ? 'border-accent text-text' : 'border-border text-muted hover:text-text'`}
          class="rounded-full border px-3.5 py-1.5 text-sm transition-colors"
        >{c}</button>
      ))}
    </div>

    {posts.length === 0 ? (
      <p class="text-muted">First posts landing here soon.</p>
    ) : (
      <div class="space-y-2">
        {posts.map((p) => (
          <a
            href={`/blog/${p.id}`}
            data-category={p.data.category}
            x-show={`cat === 'All' || cat === '${p.data.category}'`}
            class="group block rounded-xl border border-transparent p-4 -mx-4 transition-colors hover:border-border hover:bg-surface/60"
          >
            <div class="flex flex-wrap items-center gap-3 text-xs text-muted">
              <span class="rounded-full border border-border px-2 py-0.5 text-spark">{p.data.category}</span>
              <span>{fmt(p.data.date)}</span>
              <span>· {readingTime(p.body)} min read</span>
            </div>
            <h2 class="mt-2 font-display text-2xl text-text transition-colors group-hover:text-accent">{p.data.title}</h2>
            <p class="mt-1.5 text-muted">{p.data.excerpt}</p>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
