---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import BlogFilter from '../../components/BlogFilter.astro';
import BlogList from '../../components/lists/BlogList.astro';
import Pagination from '../../components/Pagination.astro';
import pages from '../../data/pages.json';
import { isSectionVisible } from '../../config/sections';
import { paginate } from '../../config/pagination';

const visible = isSectionVisible('blog');
const byDate = (a, b) => b.data.date.valueOf() - a.data.date.valueOf();
const all = visible
  ? (await getCollection('blog')).filter((p) => !p.data.draft && !p.data.hidden).sort(byDate)
  : [];

const featured = all.filter((p) => p.data.featured);
const rest = all.filter((p) => !p.data.featured);
const { slice, current, lastPage } = paginate(rest, 1);
---

<BaseLayout
  title="Blog — Mohammed Akash"
  description="Thinking in public by Mohammed Akash — notes on building with Claude, development, and ideas worth keeping."
>
  <section class="mx-auto max-w-6xl px-5 py-14">
    {!visible ? (
      <p class="py-24 text-center text-muted">This section is currently unavailable.</p>
    ) : (
    <>
    <SectionHero title={pages.blog.title} intro={pages.blog.intro} motif="blog" />

    <BlogFilter active="all" />

    {all.length === 0 ? (
      <p class="text-muted">First posts landing here soon.</p>
    ) : (
      <>
        {featured.length > 0 && (
          <section class="mb-5">
            <BlogList items={featured} cols={2} colsSm={1} masonry={false} featured />
          </section>
        )}
        <BlogList items={slice} />
        <Pagination current={current} last={lastPage} base="/blog" />
      </>
    )}
    </>
    )}
  </section>
</BaseLayout>
