---
import { getCollection, render } from 'astro:content';
import ProseLayout from '../../layouts/ProseLayout.astro';
import { isSectionVisible } from '../../config/sections';

export async function getStaticPaths() {
  if (!isSectionVisible('blog')) return [];
  const posts = (await getCollection('blog')).filter((p) => !p.data.draft && !p.data.hidden);
  return posts.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, date, category, excerpt, cover, resources } = entry.data;

const readingTime = Math.max(1, Math.round((entry.body ?? '').split(/\s+/).filter(Boolean).length / 200));
const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// Prev / next within the (visible) blog, newest-first.
const all = (await getCollection('blog'))
  .filter((p) => !p.data.draft && !p.data.hidden)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const i = all.findIndex((p) => p.id === entry.id);
const newer = i > 0 ? all[i - 1] : null;
const older = i < all.length - 1 ? all[i + 1] : null;

const postUrl = new URL(`/blog/${entry.id}`, Astro.site).href;
const schema = {
  '@type': 'BlogPosting',
  '@id': `${postUrl}#article`,
  headline: title,
  description: excerpt,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  author: { '@id': `${Astro.site}#person` },
  publisher: { '@id': `${Astro.site}#person` },
  mainEntityOfPage: postUrl,
  url: postUrl,
  articleSection: category,
  inLanguage: 'en',
  ...(cover ? { image: new URL(cover, Astro.site).href } : {}),
};
---

<ProseLayout
  title={title}
  description={excerpt}
  eyebrow={category}
  meta={`${dateStr} · ${readingTime} min read`}
  cover={cover}
  resources={resources}
  schema={schema}
  backHref="/blog"
  backLabel="All posts"
>
  <Content />

  <nav class="not-prose mt-16 flex justify-between gap-4 border-t border-border pt-8 text-sm">
    {older ? (
      <a href={`/blog/${older.id}`} class="text-muted hover:text-accent transition-colors">← {older.data.title}</a>
    ) : <span></span>}
    {newer ? (
      <a href={`/blog/${newer.id}`} class="text-right text-muted hover:text-accent transition-colors">{newer.data.title} →</a>
    ) : <span></span>}
  </nav>
</ProseLayout>
