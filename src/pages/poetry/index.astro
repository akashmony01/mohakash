---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import PoetryList from '../../components/lists/PoetryList.astro';
import Pagination from '../../components/Pagination.astro';
import pages from '../../data/pages.json';
import { isSectionVisible } from '../../config/sections';
import { paginate } from '../../config/pagination';

const visible = isSectionVisible('poetry');
const byDate = (a, b) => b.data.date.valueOf() - a.data.date.valueOf();
const all = visible
  ? (await getCollection('poetry')).filter((p) => !p.data.hidden).sort(byDate)
  : [];

// Pinned poems float into their own section on page 1; the rest paginate below.
const featured = all.filter((p) => p.data.featured);
const rest = all.filter((p) => !p.data.featured);
const { slice, current, lastPage } = paginate(rest, 1);
---

<BaseLayout
  title="Poetry — Mohammed Akash"
  description="Poems by Mohammed Akash — verses and fragments written under the sky."
>
  <section class="mx-auto max-w-6xl px-5 py-14">
    {!visible ? (
      <p class="py-24 text-center text-muted">This section is currently unavailable.</p>
    ) : (
    <>
    <SectionHero title={pages.poetry.title} intro={pages.poetry.intro} motif="poetry" />

    {all.length === 0 ? (
      <p class="text-muted">Poems landing here soon.</p>
    ) : (
      <>
        {featured.length > 0 && (
          <section class="mb-5">
            <PoetryList items={featured} cols={2} colsSm={1} masonry={false} featured />
          </section>
        )}
        <PoetryList items={slice} />
        <Pagination current={current} last={lastPage} base="/poetry" />
      </>
    )}
    </>
    )}
  </section>
</BaseLayout>
