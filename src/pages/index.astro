---
import BaseLayout from '../layouts/BaseLayout.astro';
import Newsletter from '../components/Newsletter.astro';
import About from '../components/About.astro';
import FeaturedContent from '../components/FeaturedContent.astro';
import ContactForm from '../components/ContactForm.astro';
import home from '../data/home.json';
import general from '../data/general.json';

const { hero } = home;
---

<BaseLayout>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <!-- abstract cosmic backdrop — full-bleed across the screen -->
    <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
      <div class="absolute -left-32 top-0 h-80 w-80 rounded-full bg-accent/25 blur-3xl"></div>
      <div class="absolute right-[-4rem] top-44 h-80 w-80 rounded-full bg-spark/20 blur-3xl"></div>
      <div class="absolute left-1/3 -top-24 h-72 w-72 rounded-full bg-accent/15 blur-3xl"></div>
      <!-- faint orbit rings, drifting off the right edge -->
      <svg class="absolute right-4 -top-24 h-[26rem] w-[26rem] text-accent/20" viewBox="0 0 200 200" fill="none">
        <ellipse cx="100" cy="100" rx="92" ry="38" stroke="currentColor" stroke-width="0.7" transform="rotate(-25 100 100)" />
        <ellipse cx="100" cy="100" rx="70" ry="70" stroke="currentColor" stroke-width="0.7" />
        <circle cx="14" cy="86" r="2.5" fill="currentColor" />
        <circle cx="186" cy="120" r="2" fill="currentColor" />
      </svg>
    </div>

    <div class="mx-auto max-w-6xl px-5 pt-20 pb-20 sm:pt-28">
    <div class="grid items-center gap-10 sm:grid-cols-[minmax(0,20rem)_1fr] sm:gap-14">
      <!-- Portrait. Swap the src below for a real photo; treatment applies automatically. -->
      <div class="relative mx-auto w-52 sm:mx-0 sm:w-full">
        <!-- abstract offset glow frame -->
        <div class="absolute -inset-3 -z-10 rounded-[1.9rem] bg-gradient-to-br from-accent/30 via-transparent to-spark/30 blur-lg"></div>
        <div class="relative overflow-hidden rounded-2xl bg-gradient-to-b from-accent/15 via-surface to-surface shadow-[0_0px_10px_-15px_rgba(22,25,31,0.4)] ring-1 ring-accent/20">
          <!-- abstract cosmic scene behind the cutout -->
          <div class="pointer-events-none absolute inset-0" aria-hidden="true">
            <!-- glow rising from the bottom -->
            <div class="absolute bottom-0 left-1/2 h-56 w-56 -translate-x-1/2 translate-y-1/4 rounded-full bg-accent/30 blur-2xl"></div>
            <!-- orbit rings -->
            <svg class="absolute left-1/2 top-1/2 h-[120%] w-[120%] -translate-x-1/2 -translate-y-1/2 text-accent/25" viewBox="0 0 200 200" fill="none">
              <ellipse cx="100" cy="100" rx="92" ry="40" stroke="currentColor" stroke-width="0.8" transform="rotate(-18 100 100)" />
              <ellipse cx="100" cy="100" rx="68" ry="68" stroke="currentColor" stroke-width="0.8" />
              <ellipse cx="100" cy="100" rx="40" ry="92" stroke="currentColor" stroke-width="0.8" transform="rotate(15 100 100)" />
            </svg>
            <!-- scattered stars -->
            <svg class="absolute inset-0 h-full w-full text-accent/40" viewBox="0 0 100 130" fill="currentColor">
              <circle cx="16" cy="20" r="1.4" /><circle cx="84" cy="14" r="1.1" />
              <circle cx="90" cy="60" r="1.4" /><circle cx="12" cy="74" r="1.1" />
              <circle cx="22" cy="110" r="1.2" /><circle cx="78" cy="116" r="1.4" />
            </svg>
          </div>

          <!-- light-mode portrait -->
          <img
            src={general.portraitLight}
            alt={hero.name}
            width="300" height="400"
            class="relative z-10 aspect-[3/4] w-full object-cover [filter:contrast(1.03)] dark:hidden"
          />
          <!-- dark-mode portrait -->
          <img
            src={general.portraitDark}
            alt={hero.name}
            width="300" height="400"
            class="relative z-10 hidden aspect-[3/4] w-full object-cover [filter:contrast(1.03)] dark:block"
          />
        </div>
      </div>

      <!-- Name + story -->
      <div class="text-center sm:text-left">
        <p class="text-sm font-medium text-muted">{hero.eyebrow}</p>
        <h1 class="mt-2 font-display text-5xl leading-[1.04] tracking-tight text-accent sm:text-6xl">
          {hero.name}
        </h1>

        <div class="mt-5 flex items-center justify-center gap-3 text-sm text-muted sm:justify-start">
          <span class="h-px w-8 bg-border"></span>
          <span>{hero.tagline}</span>
          <span class="h-px w-8 bg-border sm:hidden"></span>
        </div>

        <p class="mt-7 max-w-md text-pretty text-lg leading-relaxed text-muted">
          {hero.intro}
        </p>

        <a
          href="#contact"
          class="btn btn-outline mt-9 rounded-full px-5 py-2 text-sm font-medium"
        >
          {hero.ctaLabel}
        </a>
      </div>
    </div>
    </div>
  </section>

  <!-- Newsletter (primary CTA) -->
  <Newsletter />

  <!-- About -->
  <About />

  <!-- abstract divider -->
  <div class="mx-auto flex max-w-6xl items-center gap-4 px-5" aria-hidden="true">
    <span class="h-px flex-1 bg-gradient-to-r from-transparent to-border"></span>
    <svg class="text-spark" width="16" height="16" viewBox="0 0 32 32" fill="currentColor"><path d="M16 4 L17.8 14.2 L28 16 L17.8 17.8 L16 28 L14.2 17.8 L4 16 L14.2 14.2 Z" /></svg>
    <span class="h-px flex-1 bg-gradient-to-l from-transparent to-border"></span>
  </div>

  <!-- Featured / recent work (proof of activity) -->
  <FeaturedContent />

  <!-- abstract divider -->
  <div class="mx-auto flex max-w-6xl items-center gap-4 px-5" aria-hidden="true">
    <span class="h-px flex-1 bg-gradient-to-r from-transparent to-border"></span>
    <svg class="text-accent" width="16" height="16" viewBox="0 0 32 32" fill="currentColor"><path d="M16 4 L17.8 14.2 L28 16 L17.8 17.8 L16 28 L14.2 17.8 L4 16 L14.2 14.2 Z" /></svg>
    <span class="h-px flex-1 bg-gradient-to-l from-transparent to-border"></span>
  </div>

  <!-- Contact -->
  <ContactForm />
</BaseLayout>
