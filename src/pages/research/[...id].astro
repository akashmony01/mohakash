---
import { getCollection, render } from 'astro:content';
import ProseLayout from '../../layouts/ProseLayout.astro';
import { isSectionVisible } from '../../config/sections';

export async function getStaticPaths() {
  if (!isSectionVisible('research')) return [];
  const entries = (await getCollection('research')).filter((e) => !e.data.hidden);
  return entries.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, date, type, abstract, pdf, link, cover, resources } = entry.data;
const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// Prev / next within the (visible) research, newest-first like the listing.
const all = (await getCollection('research'))
  .filter((e) => !e.data.hidden)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const i = all.findIndex((e) => e.id === entry.id);
const newer = i > 0 ? all[i - 1] : null;
const older = i < all.length - 1 ? all[i + 1] : null;

const entryUrl = new URL(`/research/${entry.id}`, Astro.site).href;
const schema = {
  '@type': type === 'paper' ? 'ScholarlyArticle' : 'Article',
  '@id': `${entryUrl}#article`,
  headline: title,
  ...(abstract ? { description: abstract, abstract } : {}),
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  author: { '@id': `${Astro.site}#person` },
  publisher: { '@id': `${Astro.site}#person` },
  mainEntityOfPage: entryUrl,
  url: entryUrl,
  inLanguage: 'en',
  ...(cover ? { image: new URL(cover, Astro.site).href } : {}),
};
---

<ProseLayout
  title={title}
  description={abstract ?? `Research ${type} by Mohammed Akash.`}
  eyebrow={type}
  meta={dateStr}
  cover={cover}
  resources={resources}
  schema={schema}
  backHref="/research"
  backLabel="All research"
>
  {abstract && (
    <p class="not-prose mb-8 border-l-2 border-spark pl-4 text-muted italic">{abstract}</p>
  )}
  {(pdf || link) && (
    <div class="not-prose mb-8 flex flex-wrap gap-3 text-sm">
      {pdf && <a href={pdf} target="_blank" rel="noopener noreferrer" class="btn btn-solid rounded-lg px-3.5 py-1.5 font-medium">PDF ↗</a>}
      {link && <a href={link} target="_blank" rel="noopener noreferrer" class="btn btn-outline rounded-lg px-3.5 py-1.5 font-medium">Source ↗</a>}
    </div>
  )}
  <Content />

  <nav class="not-prose mt-16 flex justify-between gap-4 border-t border-border pt-8 text-sm">
    {older ? (
      <a href={`/research/${older.id}`} class="text-muted hover:text-accent transition-colors">← {older.data.title}</a>
    ) : <span></span>}
    {newer ? (
      <a href={`/research/${newer.id}`} class="text-right text-muted hover:text-accent transition-colors">{newer.data.title} →</a>
    ) : <span></span>}
  </nav>
</ProseLayout>
