---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import pages from '../../data/pages.json';
import { isSectionVisible } from '../../config/sections';

const visible = isSectionVisible('research');
const entries = visible
  ? (await getCollection('research'))
      .filter((e) => !e.data.hidden)
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  : [];
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
---

<BaseLayout
  title="Research — Mohammed Akash"
  description="Research by Mohammed Akash — notes, papers, and ongoing inquiry."
>
  <section class="mx-auto max-w-6xl px-5 py-14">
    {!visible ? (
      <p class="py-24 text-center text-muted">This section is currently unavailable.</p>
    ) : (
    <>
    <SectionHero
      title={pages.research.title}
      intro={pages.research.intro}
      tint="#1a8fd6"
      motif="research"
    />

    {entries.length === 0 ? (
      <p class="text-muted">Research notes landing here soon.</p>
    ) : (
      <ul class="space-y-6">
        {entries.map((e) => (
          <li class="border-b border-border pb-6">
            <a href={`/research/${e.id}`} class="group block">
              <div class="flex items-center gap-3">
                <span class="rounded-full border border-border px-2.5 py-0.5 text-xs uppercase tracking-wide text-spark">{e.data.type}</span>
                <span class="text-sm text-muted">{fmt(e.data.date)}</span>
              </div>
              <h2 class="mt-2 font-display text-xl text-text transition-colors group-hover:text-accent">{e.data.title}</h2>
              {e.data.abstract && <p class="mt-2 text-sm leading-relaxed text-muted">{e.data.abstract}</p>}
            </a>
          </li>
        ))}
      </ul>
    )}
    </>
    )}
  </section>
</BaseLayout>
