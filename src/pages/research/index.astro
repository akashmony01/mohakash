---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import ResearchList from '../../components/lists/ResearchList.astro';
import Pagination from '../../components/Pagination.astro';
import pages from '../../data/pages.json';
import { isSectionVisible } from '../../config/sections';
import { paginate } from '../../config/pagination';

const visible = isSectionVisible('research');
const byDate = (a, b) => b.data.date.valueOf() - a.data.date.valueOf();
const all = visible
  ? (await getCollection('research')).filter((e) => !e.data.hidden).sort(byDate)
  : [];

const featured = all.filter((e) => e.data.featured);
const rest = all.filter((e) => !e.data.featured);
const { slice, current, lastPage } = paginate(rest, 1);
---

<BaseLayout
  title="Research — Mohammed Akash"
  description="Research by Mohammed Akash — notes, papers, and ongoing inquiry."
>
  <section class="mx-auto max-w-6xl px-5 py-14">
    {!visible ? (
      <p class="py-24 text-center text-muted">This section is currently unavailable.</p>
    ) : (
    <>
    <SectionHero title={pages.research.title} intro={pages.research.intro} motif="research" />

    {all.length === 0 ? (
      <p class="text-muted">Research notes landing here soon.</p>
    ) : (
      <>
        {featured.length > 0 && (
          <section class="mb-5">
            <ResearchList items={featured} featured />
          </section>
        )}
        <ResearchList items={slice} />
        <Pagination current={current} last={lastPage} base="/research" />
      </>
    )}
    </>
    )}
  </section>
</BaseLayout>
