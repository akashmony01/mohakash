---
import { getCollection, render } from 'astro:content';
import ProseLayout from '../../layouts/ProseLayout.astro';
import { isSectionVisible } from '../../config/sections';

export async function getStaticPaths() {
  if (!isSectionVisible('projects')) return [];
  const projects = (await getCollection('projects')).filter((p) => !p.data.hidden);
  return projects.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, summary, stack, year, link, repo, cover, resources } = entry.data;

// Prev / next within the (visible) projects, in the same order as the listing.
const all = (await getCollection('projects'))
  .filter((p) => !p.data.hidden)
  .sort((a, b) => a.data.order - b.data.order || (b.data.year ?? 0) - (a.data.year ?? 0));
const i = all.findIndex((p) => p.id === entry.id);
const prev = i > 0 ? all[i - 1] : null;
const next = i < all.length - 1 ? all[i + 1] : null;

const projectUrl = new URL(`/projects/${entry.id}`, Astro.site).href;
const schema = {
  '@type': 'CreativeWork',
  '@id': `${projectUrl}#project`,
  name: title,
  description: summary,
  ...(year ? { dateCreated: String(year) } : {}),
  author: { '@id': `${Astro.site}#person` },
  creator: { '@id': `${Astro.site}#person` },
  url: projectUrl,
  ...(link ? { sameAs: link } : {}),
  ...(stack.length ? { keywords: stack.join(', ') } : {}),
  ...(cover ? { image: new URL(cover, Astro.site).href } : {}),
};
---

<ProseLayout
  title={title}
  description={summary}
  eyebrow={year ? `Project · ${year}` : 'Project'}
  cover={cover}
  resources={resources}
  schema={schema}
  backHref="/projects"
  backLabel="All projects"
>
  {(link || repo || stack.length > 0) && (
    <div class="not-prose mb-8 flex flex-wrap items-center gap-3 text-sm">
      {link && <a href={link} target="_blank" rel="noopener noreferrer" class="btn btn-solid rounded-lg px-3.5 py-1.5 font-medium">Live ↗</a>}
      {repo && <a href={repo} target="_blank" rel="noopener noreferrer" class="btn btn-outline rounded-lg px-3.5 py-1.5 font-medium">Code ↗</a>}
      {stack.map((s) => <span class="rounded-full border border-border px-2.5 py-0.5 text-xs text-muted">{s}</span>)}
    </div>
  )}
  <Content />

  <nav class="not-prose mt-16 flex justify-between gap-4 border-t border-border pt-8 text-sm">
    {prev ? (
      <a href={`/projects/${prev.id}`} class="text-muted hover:text-accent transition-colors">← {prev.data.title}</a>
    ) : <span></span>}
    {next ? (
      <a href={`/projects/${next.id}`} class="text-right text-muted hover:text-accent transition-colors">{next.data.title} →</a>
    ) : <span></span>}
  </nav>
</ProseLayout>
