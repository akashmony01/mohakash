---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import pages from '../../data/pages.json';
import { isSectionVisible } from '../../config/sections';

const visible = isSectionVisible('projects');
const projects = visible
  ? (await getCollection('projects'))
      .filter((p) => !p.data.hidden)
      .sort((a, b) => a.data.order - b.data.order || (b.data.year ?? 0) - (a.data.year ?? 0))
  : [];
---

<BaseLayout
  title="Projects — Mohammed Akash"
  description="Freelance web development work by Mohammed Akash — sites and apps I design and build."
>
  <section class="mx-auto max-w-6xl px-5 py-14">
    {!visible ? (
      <p class="py-24 text-center text-muted">This section is currently unavailable.</p>
    ) : (
    <>
    <SectionHero
      title={pages.projects.title}
      intro={pages.projects.intro}
      motif="projects"
    />

    {projects.length === 0 ? (
      <p class="text-muted">Work in progress — projects landing here soon.</p>
    ) : (
      <div class="grid gap-5 sm:grid-cols-2">
        {projects.map((p) => (
          <a
            href={`/projects/${p.id}`}
            class="group flex flex-col rounded-xl border border-border bg-surface p-8 card-cosmic hover:border-accent/50"
          >
            <div class="flex items-baseline justify-between gap-3">
              <h2 class="font-sans text-xl font-semibold text-text">{p.data.title}</h2>
              {p.data.year && <span class="text-sm text-muted">{p.data.year}</span>}
            </div>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{p.data.summary}</p>
            {p.data.stack.length > 0 && (
              <ul class="mt-4 flex flex-wrap gap-2">
                {p.data.stack.map((s) => (
                  <li class="rounded-full border border-border px-2.5 py-0.5 text-xs text-muted">{s}</li>
                ))}
              </ul>
            )}
            <span class="mt-5 text-accent transition-transform duration-200 group-hover:translate-x-1">View →</span>
          </a>
        ))}
      </div>
    )}
    </>
    )}
  </section>
</BaseLayout>
