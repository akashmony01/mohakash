---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import ProjectsList from '../../components/lists/ProjectsList.astro';
import Pagination from '../../components/Pagination.astro';
import pages from '../../data/pages.json';
import { isSectionVisible } from '../../config/sections';
import { paginate } from '../../config/pagination';

const visible = isSectionVisible('projects');
const byOrder = (a, b) => a.data.order - b.data.order || (b.data.year ?? 0) - (a.data.year ?? 0);
const all = visible
  ? (await getCollection('projects')).filter((p) => !p.data.hidden).sort(byOrder)
  : [];

const featured = all.filter((p) => p.data.featured);
const rest = all.filter((p) => !p.data.featured);
const { slice, current, lastPage } = paginate(rest, 1);
---

<BaseLayout
  title="Projects — Mohammed Akash"
  description="Freelance web development work by Mohammed Akash — sites and apps I design and build."
>
  <section class="mx-auto max-w-6xl px-5 py-14">
    {!visible ? (
      <p class="py-24 text-center text-muted">This section is currently unavailable.</p>
    ) : (
    <>
    <SectionHero title={pages.projects.title} intro={pages.projects.intro} motif="projects" />

    {all.length === 0 ? (
      <p class="text-muted">Work in progress — projects landing here soon.</p>
    ) : (
      <>
        {featured.length > 0 && (
          <section class="mb-5">
            <ProjectsList items={featured} cols={1} masonry={false} featured />
          </section>
        )}
        <ProjectsList items={slice} />
        <Pagination current={current} last={lastPage} base="/projects" />
      </>
    )}
    </>
    )}
  </section>
</BaseLayout>
