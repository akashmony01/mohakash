---
// Type system: Anton (display headings) + Space Grotesk (body) + JetBrains Mono
// (code), with Hind Siliguri (a rounded Bengali sans) carrying the Bangla
// poetry. Latin fonts lack Bengali glyphs, so the browser falls through to it
// per-glyph automatically. See the font tokens in global.css.
import '@fontsource/anton';
import '@fontsource-variable/space-grotesk';
import '@fontsource/jetbrains-mono';
import '@fontsource/hind-siliguri/400.css';
import '@fontsource/hind-siliguri/600.css';
import '@fontsource/hind-siliguri/700.css';
import '../styles/global.css';

import Starfield from '../components/Starfield.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import general from '../data/general.json';
import social from '../data/social.json';

const defaultTheme = general.defaultTheme ?? 'system';

interface Props {
  title?: string;
  description?: string;
  /** Social/preview image (absolute path from site root). */
  image?: string;
  /** "website" (default) or "article" for blog/research/etc. detail pages. */
  type?: 'website' | 'article';
  /** Per-page JSON-LD object(s) merged into the structured-data graph. */
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

// SEO defaults are CMS-editable (src/data/general.json → "General"); individual
// pages can still override via the title/description props.
const {
  title = general.siteTitle ?? 'Mohammed Akash — the infinite sky',
  description = general.siteDescription ??
    'Mohammed Akash (moh·akash, “the infinite sky”) — web developer, researcher, and poet. Projects, poetry, research, and notes on building with Claude.',
  image = '/og.png',
  type = 'website',
  schema,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site).href;
const siteName = general.siteTitle ?? 'Mohammed Akash — the infinite sky';

// Only emit social links that point at a real profile (placeholder entries are
// bare domains like "https://github.com/" — skip those so the entity data is clean).
const sameAs = social.socials
  .map((s) => s.url)
  .filter((u) => {
    try { return new URL(u).pathname.replace(/\/$/, '') !== ''; } catch { return false; }
  });

// Site-wide structured data: who this is (Person) + the site (WebSite). Helps
// search engines and AI assistants resolve "Mohammed Akash" to a clear entity.
const baseGraph: Record<string, unknown>[] = [
  {
    '@type': 'Person',
    '@id': `${Astro.site}#person`,
    name: 'Mohammed Akash',
    alternateName: 'moh·akash',
    url: Astro.site?.href,
    image: new URL(general.portraitLight ?? '/og.png', Astro.site).href,
    jobTitle: 'Freelance web developer, researcher, and poet',
    description:
      'Freelance web developer and NLP researcher based in Bangladesh, building in public with Claude. Writes poetry now and then, mostly in Bengali.',
    address: { '@type': 'PostalAddress', addressCountry: 'Bangladesh' },
    nationality: 'Bangladeshi',
    knowsAbout: [
      'Web development',
      'Natural language processing',
      'Machine learning',
      'Artificial intelligence',
      'Bengali poetry',
      'Building with Claude',
    ],
    alumniOf: {
      '@type': 'CollegeOrUniversity',
      name: 'Bangladesh University of Business and Technology',
    },
    ...(general.email ? { email: general.email } : {}),
    ...(sameAs.length ? { sameAs } : {}),
  },
  {
    '@type': 'WebSite',
    '@id': `${Astro.site}#website`,
    url: Astro.site?.href,
    name: siteName,
    description,
    inLanguage: 'en',
    publisher: { '@id': `${Astro.site}#person` },
  },
];

const extra = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [...baseGraph, ...extra],
};
// Cloudflare Web Analytics is enabled via the Cloudflare dashboard (automatic
// beacon injection); the CSP in public/_headers allows its script/connect hosts.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Set theme before paint to avoid a flash of the wrong mode. The
         site-wide default (dark / light / system) is CMS-editable. -->
    <script is:inline define:vars={{ defaultTheme }}>
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          var mode = saved || defaultTheme;
          if (mode === 'system') {
            mode = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          if (mode === 'dark') {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#1a8fd6" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0b0e1a" media="(prefers-color-scheme: dark)" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Mohammed Akash" />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <!-- Let search engines + AI overviews show full snippets and large image
         previews (max-snippet:-1 = no length limit). -->
    <meta
      name="robots"
      content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
    />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={title} />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Mohammed Akash — Blog" href="/rss.xml" />

    <!-- Structured data (schema.org) — site-wide Person + WebSite, plus any
         per-page schema (e.g. BlogPosting) passed in via the `schema` prop. -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="flex min-h-dvh flex-col">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded focus:bg-surface focus:px-3 focus:py-2 focus:text-text">
      Skip to content
    </a>
    <Starfield />
    <Header />
    <main id="main" class="flex-1 overflow-x-clip">
      <slot />
    </main>
    <Footer />

    <!-- Back to top -->
    <button
      x-data="{ show: false }"
      x-init="window.addEventListener('scroll', () => show = window.scrollY > 700)"
      x-show="show"
      x-cloak
      @click="window.scrollTo({ top: 0, behavior: 'smooth' })"
      aria-label="Back to top"
      class="fixed bottom-6 right-6 z-50 grid h-10 w-10 cursor-pointer place-items-center rounded-full border border-border bg-surface/90 text-text backdrop-blur transition-colors hover:border-accent hover:text-accent"
    >↑</button>

    <!-- Play the footer wordmark animation once when it scrolls into view. -->
    <script is:inline>
      (function () {
        var els = document.querySelectorAll('.brand-onview');
        if (!els.length) return;
        if (!('IntersectionObserver' in window)) {
          els.forEach(function (e) { e.classList.add('brand-play'); });
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (en) {
            if (en.isIntersecting) {
              en.target.classList.add('brand-play');
              io.unobserve(en.target);
            }
          });
        }, { threshold: 0.6 });
        els.forEach(function (e) { io.observe(e); });
      })();
    </script>
  </body>
</html>
