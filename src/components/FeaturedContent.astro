---
import { getCollection } from 'astro:content';
import home from '../data/home.json';
import { isSectionVisible } from '../config/sections';
import { youtubeEmbed } from '../config/youtube';

const { heading: featuredHeading, tagline: featuredTagline } = home.featured;

// Outline the last word of the heading for poster-style emphasis.
const fhWords = featuredHeading.split(' ');
const fhTail = fhWords.slice(-1).join(' ');
const fhHead = fhWords.slice(0, -1).join(' ');

// Relative date label, computed at build time.
function timeAgo(date: Date): string {
  const days = Math.floor((Date.now() - date.valueOf()) / 86_400_000);
  if (days <= 0) return 'today';
  if (days === 1) return 'yesterday';
  if (days < 7) return `${days} days ago`;
  if (days < 30) { const w = Math.floor(days / 7); return `${w} week${w > 1 ? 's' : ''} ago`; }
  if (days < 365) { const m = Math.floor(days / 30); return `${m} month${m > 1 ? 's' : ''} ago`; }
  const y = Math.floor(days / 365);
  return `${y} year${y > 1 ? 's' : ''} ago`;
}

const byDate = (a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf();

// Each card respects both the section toggle and per-item "hidden".
const latestBlog = isSectionVisible('blog')
  ? (await getCollection('blog')).filter((p) => !p.data.draft && !p.data.hidden).sort(byDate)[0]
  : undefined;
const latestPoem = isSectionVisible('poetry')
  ? (await getCollection('poetry')).filter((p) => !p.data.hidden).sort(byDate)[0]
  : undefined;
const latestResearch = isSectionVisible('research')
  ? (await getCollection('research')).filter((e) => !e.data.hidden).sort(byDate)[0]
  : undefined;
const projectsAll = isSectionVisible('projects')
  ? (await getCollection('projects')).filter((p) => !p.data.hidden)
  : [];
const featuredProject =
  projectsAll.find((p) => p.data.featured) ??
  projectsAll.sort((a, b) => a.data.order - b.data.order)[0];
const latestVideo = isSectionVisible('videos')
  ? (await getCollection('videos')).filter((v) => !v.data.hidden).sort(byDate)[0]
  : undefined;

// First few lines of a poem, joined as a single quoted preview. We take up to 5
// lines here (the homepage card); the 220-char clip + line-clamp-6 keep it from
// overflowing if those lines are long.
function poemPreview(body = ''): string {
  const lines = body.trim().split('\n').map((l) => l.trim()).filter(Boolean).slice(0, 5);
  return lines.join(' / ');
}

// Homepage cards show only a short slice of the (possibly long) excerpt so the
// boxes stay uniform. The full text still lives in the post; this only clips
// what the card displays. Cuts on a word boundary and adds an ellipsis.
const EXCERPT_MAX = 140;
// Poems get a higher cap: they show 3 whole lines, and Bengali fits more
// characters per line, so 140 would cut a poem mid-line.
const POEM_EXCERPT_MAX = 220;
function clip(text = '', max = EXCERPT_MAX): string {
  const t = text.trim();
  if (t.length <= max) return t;
  const cut = t.slice(0, max);
  const lastSpace = cut.lastIndexOf(' ');
  return (lastSpace > max * 0.6 ? cut.slice(0, lastSpace) : cut).replace(/[\s.,;:!?–-]+$/, '') + '…';
}

type Card = {
  label: string;
  color: string;      // cat-* token name
  title: string;
  meta: string;
  preview: string;
  href: string;
  cta: string;
  quote?: boolean;
  embed?: string;     // YouTube embed URL — renders an inline player instead of a preview
};

const cards: Card[] = [];

if (latestBlog) cards.push({
  label: 'Latest post', color: 'cat-blog',
  title: latestBlog.data.title, meta: timeAgo(latestBlog.data.date),
  preview: latestBlog.data.excerpt, href: `/blog/${latestBlog.id}`, cta: 'Read more',
});
if (latestPoem) cards.push({
  label: 'Recent poem', color: 'cat-poetry',
  title: latestPoem.data.title, meta: timeAgo(latestPoem.data.date),
  preview: poemPreview(latestPoem.body), href: `/poetry/${latestPoem.id}`, cta: 'Read more', quote: true,
});
if (featuredProject) cards.push({
  label: 'Featured project', color: 'cat-projects',
  title: featuredProject.data.title,
  meta: featuredProject.data.link ? 'Live now' : (featuredProject.data.year ? String(featuredProject.data.year) : 'Project'),
  preview: featuredProject.data.summary, href: `/projects/${featuredProject.id}`, cta: 'View project',
});
if (latestResearch) cards.push({
  label: 'Recent research', color: 'cat-research',
  title: latestResearch.data.title, meta: timeAgo(latestResearch.data.date),
  preview: latestResearch.data.abstract ?? '', href: `/research/${latestResearch.id}`, cta: 'Read more',
});
if (latestVideo) cards.push({
  // Videos share one /videos page (no per-video route), so the card links there.
  // The embed lets the visitor play it right in the card.
  label: 'Latest video', color: 'cat-videos',
  title: latestVideo.data.title, meta: timeAgo(latestVideo.data.date),
  preview: latestVideo.data.description ?? '', href: '/videos', cta: 'Watch more',
  embed: youtubeEmbed(latestVideo.data.youtube) ?? undefined,
});

const textClass: Record<string, string> = {
  'cat-blog': 'text-cat-blog',
  'cat-poetry': 'text-cat-poetry',
  'cat-projects': 'text-cat-projects',
  'cat-research': 'text-cat-research',
  'cat-videos': 'text-cat-videos',
};

// Desktop layout on a 12-column grid: an even split by card count, EXCEPT when
// the Latest-video card is present (it's always pushed last). Then it never sits
// alone awkwardly — at 3 cards it gets its own full-width row below a 50/50 pair,
// and at 4 cards the grid becomes a tidy 2×2. Span per card (12=full, 6=half,
// 4=third, 3=quarter):
const hasVideo = cards.some((c) => c.color === 'cat-videos');
const n = cards.length;
const spans =
  n === 1 ? [12] :
  n === 2 ? [6, 6] :
  n === 3 ? (hasVideo ? [6, 6, 12] : [4, 4, 4]) :
  n === 4 ? (hasVideo ? [6, 6, 6, 6] : [3, 3, 3, 3]) :
  [4, 4, 4, 6, 6];
const spanClass: Record<number, string> = {
  3: 'lg:col-span-3',
  4: 'lg:col-span-4',
  6: 'lg:col-span-6',
  12: 'lg:col-span-12',
};

// The video card (always last) plays an iframe, which makes it taller than a
// text card. When it sits in a 50/50 row (span 6), the text card beside it — the
// one right before it — gets a doubled excerpt so it fills the height instead of
// looking empty. (At span 12 the video has its own full-width row: no neighbor.)
const videoIdx = cards.findIndex((c) => c.embed);
const doubleIdx = videoIdx > 0 && spans[videoIdx] === 6 ? videoIdx - 1 : -1;
---

{cards.length > 0 && (
  <section class="mx-auto max-w-6xl px-5 py-14">
    <div class="mb-8 flex items-baseline justify-between">
      <h2 class="font-display text-4xl text-accent sm:text-5xl">{fhHead} <span class="text-hollow-thin">{fhTail}</span></h2>
      <span class="text-sm text-muted">{featuredTagline}</span>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-12">
      {cards.map((c, i) => {
        // Video card: just a label + a "View more" link top-right, then the player.
        if (c.embed) {
          return (
            <div
              class:list={['col-span-1 flex flex-col overflow-hidden rounded-xl border border-t-4 border-border bg-surface p-6 card-cosmic', spanClass[spans[i]]]}
              style={`border-top-color: var(--color-${c.color});`}
            >
              <div class="flex items-center justify-between gap-2">
                <span class={`text-xs font-medium uppercase tracking-wide ${textClass[c.color]}`}>{c.label}</span>
                <a href={c.href} class={`text-xs font-medium ${textClass[c.color]} transition-transform duration-200 hover:translate-x-0.5`}>View more →</a>
              </div>
              <div class="mt-4 aspect-video w-full overflow-hidden rounded-lg border border-border bg-black">
                <iframe
                  class="h-full w-full border-0"
                  src={c.embed}
                  title={c.title}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  allowfullscreen
                ></iframe>
              </div>
            </div>
          );
        }
        // Double the excerpt for the card sharing a 50/50 row with the video.
        const isDouble = i === doubleIdx;
        const max = (c.quote ? POEM_EXCERPT_MAX : EXCERPT_MAX) * (isDouble ? 2 : 1);
        const clampCls = c.quote
          ? (isDouble ? 'line-clamp-[12]' : 'line-clamp-6')
          : (isDouble ? 'line-clamp-[8]' : 'line-clamp-4');
        return (
          <a
            href={c.href}
            class:list={['group col-span-1 flex flex-col rounded-xl border border-t-4 border-border bg-surface p-6 card-cosmic', spanClass[spans[i]]]}
            style={`border-top-color: var(--color-${c.color});`}
          >
            <div class="flex items-center justify-between gap-2">
              <span class={`text-xs font-medium uppercase tracking-wide ${textClass[c.color]}`}>{c.label}</span>
              <span class="text-xs text-muted">{c.meta}</span>
            </div>
            <h3 class="mt-4 font-sans text-lg font-semibold leading-snug tracking-tight text-text">{c.title}</h3>
            <p class:list={['mt-4 flex-1 text-sm leading-relaxed text-muted', clampCls, c.quote && 'italic']}>
              {c.quote ? `“${clip(c.preview, max)}”` : clip(c.preview, max)}
            </p>
            <span class={`mt-5 text-sm ${textClass[c.color]} transition-transform duration-200 group-hover:translate-x-1`}>{c.cta} →</span>
          </a>
        );
      })}
    </div>
  </section>
)}
