---
import { getCollection } from 'astro:content';
import home from '../data/home.json';
import { isSectionVisible } from '../config/sections';

const { heading: featuredHeading, tagline: featuredTagline } = home.featured;

// Relative date label, computed at build time.
function timeAgo(date: Date): string {
  const days = Math.floor((Date.now() - date.valueOf()) / 86_400_000);
  if (days <= 0) return 'today';
  if (days === 1) return 'yesterday';
  if (days < 7) return `${days} days ago`;
  if (days < 30) { const w = Math.floor(days / 7); return `${w} week${w > 1 ? 's' : ''} ago`; }
  if (days < 365) { const m = Math.floor(days / 30); return `${m} month${m > 1 ? 's' : ''} ago`; }
  const y = Math.floor(days / 365);
  return `${y} year${y > 1 ? 's' : ''} ago`;
}

const byDate = (a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf();

// Each card respects both the section toggle and per-item "hidden".
const latestBlog = isSectionVisible('blog')
  ? (await getCollection('blog')).filter((p) => !p.data.draft && !p.data.hidden).sort(byDate)[0]
  : undefined;
const latestPoem = isSectionVisible('poetry')
  ? (await getCollection('poetry')).filter((p) => !p.data.hidden).sort(byDate)[0]
  : undefined;
const latestResearch = isSectionVisible('research')
  ? (await getCollection('research')).filter((e) => !e.data.hidden).sort(byDate)[0]
  : undefined;
const projectsAll = isSectionVisible('projects')
  ? (await getCollection('projects')).filter((p) => !p.data.hidden)
  : [];
const featuredProject =
  projectsAll.find((p) => p.data.featured) ??
  projectsAll.sort((a, b) => a.data.order - b.data.order)[0];

// First few lines of a poem, joined as a single quoted preview.
function poemPreview(body = ''): string {
  const lines = body.trim().split('\n').map((l) => l.trim()).filter(Boolean).slice(0, 3);
  return lines.join(' / ');
}

type Card = {
  label: string;
  color: string;      // cat-* token name
  title: string;
  meta: string;
  preview: string;
  href: string;
  cta: string;
  quote?: boolean;
};

const cards: Card[] = [];

if (latestBlog) cards.push({
  label: 'Latest post', color: 'cat-blog',
  title: latestBlog.data.title, meta: timeAgo(latestBlog.data.date),
  preview: latestBlog.data.excerpt, href: `/blog/${latestBlog.id}`, cta: 'Read more',
});
if (latestPoem) cards.push({
  label: 'Recent poem', color: 'cat-poetry',
  title: latestPoem.data.title, meta: timeAgo(latestPoem.data.date),
  preview: poemPreview(latestPoem.body), href: `/poetry/${latestPoem.id}`, cta: 'Read more', quote: true,
});
if (featuredProject) cards.push({
  label: 'Featured project', color: 'cat-projects',
  title: featuredProject.data.title,
  meta: featuredProject.data.link ? 'Live now' : (featuredProject.data.year ? String(featuredProject.data.year) : 'Project'),
  preview: featuredProject.data.summary, href: `/projects/${featuredProject.id}`, cta: 'View project',
});
if (latestResearch) cards.push({
  label: 'Recent research', color: 'cat-research',
  title: latestResearch.data.title, meta: timeAgo(latestResearch.data.date),
  preview: latestResearch.data.abstract ?? '', href: `/research/${latestResearch.id}`, cta: 'Read more',
});

const textClass: Record<string, string> = {
  'cat-blog': 'text-cat-blog',
  'cat-poetry': 'text-cat-poetry',
  'cat-projects': 'text-cat-projects',
  'cat-research': 'text-cat-research',
};
---

{cards.length > 0 && (
  <section class="mx-auto max-w-6xl px-5 py-16">
    <div class="mb-8 flex items-baseline justify-between">
      <h2 class="font-display text-3xl text-accent sm:text-4xl">{featuredHeading}</h2>
      <span class="text-sm text-muted">{featuredTagline}</span>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {cards.map((c) => (
        <a
          href={c.href}
          class="group flex flex-col rounded-xl border border-t-4 border-border bg-surface p-6 card-cosmic"
          style={`border-top-color: var(--color-${c.color});`}
        >
          <div class="flex items-center justify-between gap-2">
            <span class={`text-xs font-medium uppercase tracking-wide ${textClass[c.color]}`}>{c.label}</span>
            <span class="text-xs text-muted">{c.meta}</span>
          </div>
          <h3 class="mt-3 font-display text-lg leading-snug text-text">{c.title}</h3>
          <p class={`mt-2 flex-1 text-sm leading-relaxed text-muted ${c.quote ? 'italic' : ''}`}>
            {c.quote ? `“${c.preview}”` : c.preview}
          </p>
          <span class={`mt-5 text-sm ${textClass[c.color]} transition-transform duration-200 group-hover:translate-x-1`}>{c.cta} →</span>
        </a>
      ))}
    </div>
  </section>
)}
