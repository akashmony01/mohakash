---
import { socials, email } from '../config/site';
import BrandLogo from './BrandLogo.astro';
import nav from '../data/navigation.json';

const year = new Date().getFullYear();
const links = nav.footer;
---

<footer class="relative mt-24 overflow-hidden border-t border-border bg-surface text-text backdrop-blur">
  <!-- abstract sky elements -->
  <div class="pointer-events-none absolute -left-24 -top-24 h-72 w-72 rounded-full bg-accent/10 blur-3xl" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -bottom-28 left-1/3 h-72 w-72 rounded-full bg-accent/10 blur-3xl" aria-hidden="true"></div>
  <svg class="pointer-events-none absolute -right-10 -top-16 h-72 w-72 text-accent/20" viewBox="0 0 200 200" fill="none" aria-hidden="true">
    <ellipse cx="100" cy="100" rx="92" ry="40" stroke="currentColor" stroke-width="0.8" transform="rotate(-20 100 100)" />
    <ellipse cx="100" cy="100" rx="68" ry="68" stroke="currentColor" stroke-width="0.8" />
    <circle cx="14" cy="80" r="2.4" fill="currentColor" />
    <circle cx="186" cy="120" r="2" fill="currentColor" />
  </svg>
  <!-- constellation, lower-left -->
  <svg class="pointer-events-none absolute bottom-6 left-10 h-28 w-44 text-accent/25" viewBox="0 0 160 96" fill="none" aria-hidden="true">
    <g stroke="currentColor" stroke-width="0.8">
      <line x1="10" y1="70" x2="45" y2="40" /><line x1="45" y1="40" x2="85" y2="55" /><line x1="85" y1="55" x2="120" y2="25" /><line x1="120" y1="25" x2="150" y2="45" />
    </g>
    <g fill="currentColor">
      <circle cx="10" cy="70" r="2" /><circle cx="45" cy="40" r="2.4" /><circle cx="85" cy="55" r="2" /><circle cx="120" cy="25" r="2.4" /><circle cx="150" cy="45" r="1.8" />
    </g>
  </svg>
  <!-- scattered stars -->
  <svg class="pointer-events-none absolute right-1/4 bottom-10 h-24 w-24 text-accent/30" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true">
    <circle cx="20" cy="30" r="1.6" /><circle cx="60" cy="15" r="1.2" /><circle cx="80" cy="55" r="1.8" /><circle cx="40" cy="70" r="1.3" />
  </svg>

  <div class="relative mx-auto max-w-6xl px-5 pt-14 pb-10">
    <div class="flex flex-col gap-10 sm:flex-row sm:items-start sm:justify-between">
      <!-- left: logo + tagline -->
      <div class="flex flex-col gap-3">
        <BrandLogo class="text-accent" trigger="view" />
        <p class="text-sm text-muted"><span class="font-medium text-text">moh·akash</span> — “the infinite sky.”</p>
      </div>

      <!-- right: site menu (top) + social menu (bottom), right-aligned on desktop -->
      <div class="flex flex-col gap-4 sm:items-end sm:text-right">
        <ul class="flex flex-wrap gap-x-5 gap-y-2 text-sm font-semibold text-text sm:justify-end">
          {links.map((l) => (
            <li><a href={l.href} class="transition-colors hover:text-accent">{l.label}</a></li>
          ))}
          <li><a href="/rss.xml" class="transition-colors hover:text-accent">RSS</a></li>
        </ul>
        <ul class="flex flex-wrap gap-x-5 gap-y-2 text-sm font-medium text-muted sm:justify-end">
          <li><a href={`mailto:${email}`} class="transition-colors hover:text-accent">Email</a></li>
          {socials.map((s) => (
            <li><a href={s.url} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-accent">{s.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- divider -->
    <div class="mt-10 border-t border-border"></div>

    <p class="mt-6 text-xs text-muted">
      © {year} Mohammed Akash · built under an open sky
    </p>
  </div>
</footer>
