---
/*
  Distinct-but-cohesive hero banner for each section. A soft tinted glow + a
  faint celestial motif give each section its own identity while staying within
  the palette.
*/
interface Props {
  title: string;
  intro: string;
  tint?: string;                                  // glow color (defaults to sky-blue)
  motif?: 'poetry' | 'research' | 'projects' | 'blog' | 'videos';
}

const { title, intro, tint = '#1a8fd6', motif } = Astro.props;

// Outline the last word of the title for poster-style emphasis (matches the
// homepage section headings). Single-word titles stay fully solid.
const tWords = title.trim().split(/\s+/);
const tTail = tWords.length > 1 ? tWords.slice(-1).join(' ') : '';
const tHead = tWords.length > 1 ? tWords.slice(0, -1).join(' ') : title;
---

<header class="relative mb-12 overflow-hidden rounded-2xl border border-border bg-surface px-6 py-12 shadow-[0_6px_24px_rgba(43,47,58,0.05)] sm:px-10 sm:py-16">
  <!-- tinted glow -->
  <div
    class="pointer-events-none absolute -left-16 -top-20 h-64 w-64 rounded-full blur-3xl"
    style={`background: radial-gradient(circle, ${tint}33, transparent 70%);`}
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute -bottom-24 right-1/4 h-56 w-56 rounded-full blur-3xl"
    style={`background: radial-gradient(circle, ${tint}22, transparent 70%);`}
    aria-hidden="true"
  ></div>

  <!-- abstract orbit rings, lower-left -->
  <svg
    class="pointer-events-none absolute -bottom-16 -left-10 h-64 w-64 opacity-[0.18]"
    viewBox="0 0 200 200" fill="none" aria-hidden="true"
    style={`color: ${tint};`}
  >
    <ellipse cx="100" cy="100" rx="92" ry="38" stroke="currentColor" stroke-width="0.8" transform="rotate(25 100 100)" />
    <ellipse cx="100" cy="100" rx="68" ry="68" stroke="currentColor" stroke-width="0.8" />
    <circle cx="14" cy="120" r="2.4" fill="currentColor" />
  </svg>

  <!-- section motif, top-right -->
  <svg
    class="pointer-events-none absolute -right-6 -top-4 h-40 w-40 opacity-20 sm:right-6 sm:h-48 sm:w-48"
    viewBox="0 0 100 100" fill="none" aria-hidden="true"
    style={`color: ${tint};`}
  >
    {motif === 'poetry' && (
      <g stroke="currentColor" stroke-width="1">
        <line x1="20" y1="25" x2="45" y2="40" />
        <line x1="45" y1="40" x2="70" y2="30" />
        <line x1="45" y1="40" x2="55" y2="70" />
        <line x1="55" y1="70" x2="80" y2="80" />
        <circle cx="20" cy="25" r="2.5" fill="currentColor" stroke="none" />
        <circle cx="45" cy="40" r="3" fill="currentColor" stroke="none" />
        <circle cx="70" cy="30" r="2.5" fill="currentColor" stroke="none" />
        <circle cx="55" cy="70" r="2.5" fill="currentColor" stroke="none" />
        <circle cx="80" cy="80" r="2" fill="currentColor" stroke="none" />
      </g>
    )}
    {motif === 'research' && (
      <g stroke="currentColor" stroke-width="1" fill="none">
        <ellipse cx="50" cy="50" rx="38" ry="16" />
        <ellipse cx="50" cy="50" rx="38" ry="16" transform="rotate(60 50 50)" />
        <ellipse cx="50" cy="50" rx="38" ry="16" transform="rotate(120 50 50)" />
        <circle cx="50" cy="50" r="4" fill="currentColor" stroke="none" />
      </g>
    )}
    {motif === 'projects' && (
      <g fill="currentColor">
        {[20, 40, 60, 80].map((y) => [20, 40, 60, 80].map((x) => (
          <circle cx={x} cy={y} r="1.6" />
        )))}
      </g>
    )}
    {motif === 'blog' && (
      <g fill="currentColor">
        <path d="M50 18 L52 32 L66 34 L52 36 L50 50 L48 36 L34 34 L48 32 Z" />
        <circle cx="74" cy="24" r="2" />
        <circle cx="28" cy="58" r="1.6" opacity="0.8" />
        <circle cx="68" cy="64" r="1.4" opacity="0.7" />
        <circle cx="40" cy="74" r="1.8" opacity="0.6" />
      </g>
    )}
    {motif === 'videos' && (
      <g stroke="currentColor" stroke-width="1" fill="none">
        <circle cx="50" cy="50" r="30" />
        <path d="M44 38 L66 50 L44 62 Z" fill="currentColor" stroke="none" />
        <circle cx="20" cy="22" r="1.8" fill="currentColor" stroke="none" />
        <circle cx="82" cy="76" r="1.6" fill="currentColor" stroke="none" />
      </g>
    )}
  </svg>

  <div class="relative max-w-2xl">
    <h1 class="text-4xl text-accent sm:text-5xl">{tHead} {tTail && <span class="text-hollow-thin">{tTail}</span>}</h1>
    <p class="mt-5 text-lg text-muted">{intro}</p>
  </div>
</header>
