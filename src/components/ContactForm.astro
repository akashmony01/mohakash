---
// The form POSTs to PUBLIC_CONTACT_ENDPOINT (set to /api/contact in the build
// environment) which is handled by the Cloudflare Pages Function in
// functions/api/contact.ts. Until that env var is set the form renders and
// validates but tells the visitor it isn't connected yet.
// PUBLIC_TURNSTILE_SITE_KEY enables the (invisible) Cloudflare Turnstile
// anti-spam widget; without it the widget is simply omitted.
import { socials, email } from '../config/site';

const endpoint = import.meta.env.PUBLIC_CONTACT_ENDPOINT ?? '';
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';

const openTo = [
  'Consulting & web projects',
  'Research collaborations',
  'A kind word about a poem',
];
---

<section id="contact" class="mx-auto max-w-6xl px-5 py-20 scroll-mt-24">
  <div class="rounded-2xl border border-border bg-surface p-8 shadow-[0_6px_24px_rgba(43,47,58,0.05)] sm:p-12">
    <div class="grid gap-10 sm:grid-cols-2 sm:gap-14">
      <!-- Invitation -->
      <div class="relative flex flex-col">
        <p class="text-xs uppercase tracking-[0.2em] text-spark">Contact</p>
        <h2 class="mt-3 font-display text-3xl leading-tight text-accent sm:text-4xl">
          Let's make something under an open sky.
        </h2>
        <p class="mt-4 text-muted">
          A project, a question, a poem you liked — the sky's open. I read
          everything and reply to most things within a day or two.
        </p>

        <ul class="mt-7 space-y-2.5">
          {openTo.map((item) => (
            <li class="flex items-center gap-3 text-sm text-text/90">
              <svg class="shrink-0 text-accent" width="13" height="13" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
                <path d="M16 4 L17.8 14.2 L28 16 L17.8 17.8 L16 28 L14.2 17.8 L4 16 L14.2 14.2 Z" />
              </svg>
              {item}
            </li>
          ))}
        </ul>

        <!-- find me elsewhere -->
        <div class="mt-8">
          <p class="text-xs uppercase tracking-[0.2em] text-muted">Find me on</p>
          <ul class="mt-3 flex flex-wrap gap-x-4 gap-y-2 text-sm">
            <li>
              <a href={`mailto:${email}`} class="text-text/90 underline decoration-border underline-offset-4 transition-colors hover:text-accent hover:decoration-accent">Email</a>
            </li>
            {socials.map((s) => (
              <li>
                <a href={s.url} target="_blank" rel="noopener noreferrer" class="text-text/90 underline decoration-border underline-offset-4 transition-colors hover:text-accent hover:decoration-accent">{s.label}</a>
              </li>
            ))}
          </ul>
        </div>

        <!-- small constellation art -->
        <svg class="mt-8 hidden h-20 w-40 opacity-25 sm:block" viewBox="0 0 160 96" fill="none" aria-hidden="true" style="color: var(--color-accent);">
          <g stroke="currentColor" stroke-width="1">
            <line x1="10" y1="70" x2="45" y2="40" />
            <line x1="45" y1="40" x2="85" y2="55" />
            <line x1="85" y1="55" x2="120" y2="25" />
            <line x1="120" y1="25" x2="150" y2="45" />
          </g>
          <g fill="currentColor">
            <circle cx="10" cy="70" r="2.5" />
            <circle cx="45" cy="40" r="3" />
            <circle cx="85" cy="55" r="2.5" />
            <circle cx="120" cy="25" r="3" />
            <circle cx="150" cy="45" r="2" />
          </g>
        </svg>
      </div>

      <!-- Form -->
      <form
        x-data={`{
          endpoint: ${JSON.stringify(endpoint)},
          status: 'idle',
          errorMsg: '',
          form: { name: '', email: '', message: '', company: '' },
          async submit() {
            if (this.form.company) { this.status = 'success'; return; } /* honeypot */
            this.status = 'sending'; this.errorMsg = '';
            if (!this.endpoint) {
              this.status = 'error';
              this.errorMsg = 'The contact form isn’t connected yet — email me directly for now.';
              return;
            }
            try {
              const token = window.turnstile ? window.turnstile.getResponse() : '';
              const res = await fetch(this.endpoint, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name: this.form.name, email: this.form.email, message: this.form.message, company: this.form.company, token }),
              });
              if (!res.ok) throw new Error('bad status');
              this.status = 'success';
              this.form = { name: '', email: '', message: '', company: '' };
              if (window.turnstile) window.turnstile.reset();
            } catch (e) {
              this.status = 'error';
              this.errorMsg = 'Something went wrong sending that. Please try again, or email me directly.';
            }
          }
        }`}
        @submit.prevent="submit()"
      >
        <!-- success state -->
        <div x-show="status === 'success'" x-cloak class="flex h-full flex-col items-center justify-center rounded-lg border border-accent/40 bg-bg/40 px-5 py-10 text-center">
          <p class="font-display text-xl text-text">Thank you — message sent.</p>
          <p class="mt-2 text-sm text-muted">I'll get back to you soon.</p>
        </div>

        <!-- fields -->
        <div x-show="status !== 'success'" class="space-y-4">
          <!-- honeypot -->
          <div class="absolute left-[-9999px]" aria-hidden="true">
            <label>Company <input type="text" x-model="form.company" tabindex="-1" autocomplete="off" /></label>
          </div>

          <label class="block">
            <span class="mb-1.5 block text-sm text-muted">Name</span>
            <input
              type="text" required x-model="form.name"
              class="w-full rounded-lg border border-border bg-bg/50 px-3.5 py-2.5 text-text placeholder:text-muted/60 focus:border-accent focus:outline-none"
              placeholder="Your name"
            />
          </label>
          <label class="block">
            <span class="mb-1.5 block text-sm text-muted">Email</span>
            <input
              type="email" required x-model="form.email"
              class="w-full rounded-lg border border-border bg-bg/50 px-3.5 py-2.5 text-text placeholder:text-muted/60 focus:border-accent focus:outline-none"
              placeholder="you@example.com"
            />
          </label>
          <label class="block">
            <span class="mb-1.5 block text-sm text-muted">Message</span>
            <textarea
              required rows="4" x-model="form.message"
              class="w-full resize-y rounded-lg border border-border bg-bg/50 px-3.5 py-2.5 text-text placeholder:text-muted/60 focus:border-accent focus:outline-none"
              placeholder="Tell me what's on your mind…"
            ></textarea>
          </label>

          <p x-show="status === 'error'" x-cloak class="text-sm text-spark" x-text="errorMsg"></p>

          {turnstileSiteKey && (
            <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="auto"></div>
          )}

          <button
            type="submit"
            :disabled="status === 'sending'"
            class="btn btn-solid w-full rounded-lg px-5 py-2.5 font-medium disabled:opacity-60 sm:w-auto"
          >
            <span x-show="status !== 'sending'">Send →</span>
            <span x-show="status === 'sending'" x-cloak>Sending…</span>
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

{turnstileSiteKey && (
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>
)}
