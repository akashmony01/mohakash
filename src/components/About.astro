---
// Homepage "about" section. Copy + facts are CMS-editable
// (src/data/home.json → "Home page" → About).
import home from '../data/home.json';

const { eyebrow, heading, paragraphs, facts } = home.about;
---

<section id="about" class="relative mx-auto max-w-6xl overflow-hidden px-5 py-12">
  <!-- subtle abstract -->
  <div class="pointer-events-none absolute -right-24 top-0 h-72 w-72 rounded-full bg-accent/10 blur-3xl" aria-hidden="true"></div>
  <svg class="pointer-events-none absolute -left-20 bottom-0 h-64 w-64 text-accent/10" viewBox="0 0 200 200" fill="none" aria-hidden="true">
    <ellipse cx="100" cy="100" rx="92" ry="40" stroke="currentColor" stroke-width="0.8" transform="rotate(20 100 100)" />
    <ellipse cx="100" cy="100" rx="64" ry="64" stroke="currentColor" stroke-width="0.8" />
  </svg>

  <div class="relative grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:gap-16">
    <!-- intro -->
    <div>
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-spark">{eyebrow}</p>
      <h2 class="mt-3 font-display text-3xl text-accent sm:text-4xl">{heading}</h2>
      {paragraphs.map((p, i) => (
        <p class:list={['text-pretty leading-relaxed text-muted', i === 0 ? 'mt-6' : 'mt-4']}>{p}</p>
      ))}
    </div>

    <!-- facts -->
    <dl class="grid gap-px overflow-hidden rounded-2xl border border-border bg-border sm:grid-cols-2">
      {facts.map((f) => (
        <div class="bg-surface p-6">
          <dt class="text-xs font-medium uppercase tracking-[0.15em] text-accent">{f.label}</dt>
          <dd class="mt-2 text-sm leading-relaxed text-text">{f.value}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>
